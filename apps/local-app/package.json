{
    "name":  "@braiser/local-app",
    "version":  "0.1.0",
    "private":  true,
    "type":  "module",
    "main":  "dist/main/main.js",
    "scripts":  {
                    "build":  "npm run build:main \u0026\u0026 npm run build:renderer",
                    "build:main":  "tsc -p tsconfig.node.json",
                    "build:renderer":  "vite build",
                    "dev":  "concurrently -k --success first \"vite --host 127.0.0.1\" \"npm run dev:electron\"",
                    "dev:electron":  "wait-on tcp:5173 \u0026\u0026 tsc -p tsconfig.node.json \u0026\u0026 cmd /d /c \"set ELECTRON_RUN_AS_NODE=\u0026 electron . --disable-gpu --disable-gpu-sandbox --in-process-gpu\"",
                    "typecheck":  "tsc -p tsconfig.node.json --noEmit \u0026\u0026 tsc -p tsconfig.renderer.json --noEmit"
                },
    "dependencies":  {
                         "@braiser/llm":  "0.1.0",
                         "@braiser/storage":  "0.1.0",
                         "@vitejs/plugin-react":  "^5.0.0",
                         "react":  "^19.0.0",
                         "react-dom":  "^19.0.0",
                         "vite":  "^7.0.0"
                     },
    "devDependencies":  {
                            "@types/node":  "^24.0.0",
                            "@types/react":  "^19.0.0",
                            "@types/react-dom":  "^19.0.0",
                            "concurrently":  "^9.0.0",
                            "electron":  "37.10.3",
                            "typescript":  "^5.9.0",
                            "wait-on":  "^8.0.0"
                        }
}
